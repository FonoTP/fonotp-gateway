{
  "name": "fonotp-webrtc-gateway",
  "version": "0.1.0",
  "description": "WebRTC gateway server for real-time voice services",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "check": "find src -name '*.js' -print0 | xargs -0 -n1 node --check",
    "mock:voice": "node src/mock-voice-service.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/static": "^8.0.0",
    "@roamhq/wrtc": "^0.9.0",
    "@fastify/websocket": "^11.0.2",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "pg": "^8.13.1",
    "ws": "^8.18.0"
  }
}
